# Copie ce fichier en `.env` puis renseigne les vraies valeurs.
# Ne committe jamais le `.env` réel (il est ignoré par git).

# --- Base de données (PostgreSQL) ---
# Local   : postgresql://user:password@localhost:5432/brain?schema=public
# Supabase: connection string du projet (onglet Database > Connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/brain?schema=public"

# --- Better Auth ---
# Génère un secret : openssl rand -base64 32
BETTER_AUTH_SECRET="change-me"
# URL de base de l'application (sans slash final)
BETTER_AUTH_URL="http://localhost:3000"

# --- OAuth (optionnel, à activer plus tard) ---
# La structure est prête pour ajouter des providers OAuth dans lib/auth.ts.
# Renseigne alors les identifiants ici, par exemple :
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
