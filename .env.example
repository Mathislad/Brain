# Copie ce fichier en `.env` puis renseigne les vraies valeurs.
# Ne committe jamais le `.env` réel (il est ignoré par git).

# --- Site public ---
NEXT_PUBLIC_SITE_URL=https://ton-app.vercel.app

# --- Prise de rendez-vous F5L ---
# Utilisé dans la fenêtre d'activation client avant le paiement.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/f5l-agency/audit-gratuit

# --- Supabase ---
# Supabase Dashboard → ton projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://TON_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ta_clé_anon_ici"

# Supabase Dashboard → ton projet → Settings → API → "service_role" (NE JAMAIS exposer côté client)
SUPABASE_SERVICE_ROLE_KEY="ta_clé_service_role_ici"

# --- Base de données (Prisma) ---
# RUNTIME (serverless Vercel) → POOLER transaction mode, port 6543.
# Supabase Dashboard → Settings → Database → Connection pooling (Transaction).
DATABASE_URL="postgresql://postgres.TON_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# MIGRATIONS (prisma migrate deploy) → connexion DIRECTE, port 5432.
# Supabase Dashboard → Settings → Database → Connection string (URI).
# En local tu peux n'utiliser QUE DATABASE_URL en direct (5432) et laisser DIRECT_URL vide.
DIRECT_URL="postgresql://postgres:PASSWORD@db.TON_PROJECT_REF.supabase.co:5432/postgres"

# --- Google Calendar ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client Web.
# URI de redirection autorisée :
# https://ton-app.vercel.app/api/google-calendar/callback
GOOGLE_CLIENT_ID="ton_client_id_google"
GOOGLE_CLIENT_SECRET="ton_client_secret_google"

# Optionnel mais recommandé : 32+ caractères aléatoires pour chiffrer les tokens Google.
# Si absent, Brain utilise une clé serveur existante (SUPABASE_SERVICE_ROLE_KEY ou DATABASE_URL).
GOOGLE_TOKEN_ENCRYPTION_KEY="une_cle_aleatoire_de_32_caracteres_minimum"
