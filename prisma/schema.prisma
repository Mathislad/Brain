generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProspectStatus {
  TODO
  IN_PROGRESS
  DONE
  CLIENT_ACTIF
}

enum AppRole {
  OWNER
  ADMIN
  CLIENT
}

model Prospect {
  id             String         @id @default(cuid())
  userId         String

  nom            String
  entreprise     String?
  email          String?
  telephone      String?
  ville          String?
  activite       String?

  status         ProspectStatus @default(TODO)
  canal          String?
  source         String?

  instagram      String?
  facebook       String?
  linkedin       String?
  siteInternet   String?

  note             String?
  prochaineAction  String?
  derniereAction   String?
  provenance       String?

  // Facturation (client)
  formule        String?
  montantTotal   Int?       // en centimes
  devisSigne     Boolean    @default(false)
  payments       Payment[]

  // Référence externe pour la déduplication lors des imports
  externalId     String?
  externalSource String?
  recuLe         DateTime?

  links          ClientLink[]
  documents      Document[]
  sites          Site[]
  organization   Organization?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, externalId])
}

model ClientLink {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  // "PROJECT" | "FILE" | "WEB" | "CONTACT"
  category   String
  label      String
  value      String

  createdAt  DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  amount     Int      // en centimes
  label      String?
  paidAt     DateTime @default(now())

  createdAt  DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
}

model AccountingEntry {
  id        String   @id @default(cuid())
  userId    String

  // "income" | "expense"
  type      String
  title     String
  amount    Int      // en centimes
  date      DateTime
  note      String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model Document {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  // "DEVIS" | "FACTURE" | "CONTRAT"
  type       String
  templateId String
  reference  String
  title      String
  // "DRAFT" | "SENT" | "SIGNED" | "PAID" | "CANCELLED"
  status     String   @default("DRAFT")
  amount     Int?     // en centimes
  data       Json?
  issuedAt   DateTime @default(now())

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([userId, type, reference])
  @@index([userId])
  @@index([prospectId])
  @@index([userId, type])
}

// ─── Liste rouge « Ne pas rappeler » ────────────────────────────────────────
model DoNotCall {
  id              String   @id @default(cuid())
  userId          String

  phone           String
  normalizedPhone String
  note            String?

  createdAt       DateTime @default(now())

  @@unique([userId, normalizedPhone])
  @@index([userId])
}

// ─── Todolist ────────────────────────────────────────────────────────────────
model TodoItem {
  id        String   @id @default(cuid())
  userId    String

  title     String
  context   String?
  status    String   @default("TODO")    // TODO | IN_PROGRESS | DONE
  priority  String   @default("MEDIUM")  // LOW | MEDIUM | HIGH
  dueDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

// ─── Réseaux sociaux — idées de contenu ─────────────────────────────────────
model ContentIdea {
  id            String   @id @default(cuid())
  userId        String

  title         String
  angle         String?
  format        String   // "simple" | "short"
  platform      String
  plannedSlotId String?
  steps         Json     @default("{}")  // { script, tournage, montage, publication }

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ─── Lancement — configuration des sessions ──────────────────────────────────
model LaunchConfig {
  id        String   @id @default(cuid())
  userId    String   @unique

  sessions  Json     @default("[]")  // LaunchSession[]

  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Agenda — connexion Google Calendar ─────────────────────────────────────
model GoogleCalendarConnection {
  id           String   @id @default(cuid())
  userId       String   @unique

  googleEmail  String?
  accessToken  String
  refreshToken String?
  tokenType    String?
  scope        String?
  expiresAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

// ─── Contrats ────────────────────────────────────────────────────────────────
model Contrat {
  id         String   @id @default(cuid())
  userId     String

  clientNom  String
  clientSiret String?
  services   String[]
  total      String?
  dureeMois  Int
  dateDebut  DateTime?
  dateSig    DateTime?
  statut     String   @default("brouillon") // brouillon | envoye | signe | archive
  storagePath String?                        // chemin dans Supabase Storage
  formData   Json                            // toutes les vars pour régénération
  notes      String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([userId, statut])
}

// ─── Bibliothèque de prompts ─────────────────────────────────────────────────
model Prompt {
  id        String   @id @default(cuid())
  userId    String

  title     String
  category  String
  content   String
  tags      String[]
  favorite  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, category])
}

// ─── CMS « Site internet » ──────────────────────────────────────────────────
// Site = back-office du site d'un client. Le site live (construit séparément)
// lit ce contenu via l'API publique /api/public/site/[slug].
model Site {
  id         String   @id @default(cuid())
  userId     String              // propriétaire F5L
  prospectId String?             // lien optionnel vers la fiche client (Prospect)

  name       String
  slug       String   @unique    // identifiant public pour l'API
  domain     String?             // domaine du site live (futur: restreindre le CORS)
  logoUrl    String?
  published  Boolean  @default(true)

  items      SiteItem[]
  prospect   Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

model SiteItem {
  id          String   @id @default(cuid())
  userId      String
  siteId      String

  type        String   // "OFFER" | "PRODUCT"
  title       String
  description String?
  price       Int?     // en centimes
  imageUrl    String?
  order       Int      @default(0)
  visible     Boolean  @default(true)

  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([siteId])
}

// ─── Portail client F5L Brain ────────────────────────────────────────────────

model Organization {
  id             String               @id @default(cuid())
  name           String
  type           String               @default("client")  // 'client' | 'internal'
  status         String               @default("pending") // 'pending' | 'active' | 'suspended'
  prospectId     String?              @unique

  // Entité légale — renseignée/corrigée pendant l'onboarding, lue par devis/contrats
  siret          String?
  adresse        String?
  formeJuridique String?
  representant   String?

  prospect       Prospect?            @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  members        OrganizationMember[]
  billing        OrganizationBilling?
  invitations    ClientInvitation[]
  documents      ClientDocument[]
  features       OrganizationFeature[]

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([type])
  @@index([status])
  @@index([prospectId])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           AppRole      @default(CLIENT)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model ClientInvitation {
  id               String       @id @default(cuid())
  organizationId   String
  contactEmail     String
  accessToken      String       @unique
  tokenExpiresAt   DateTime
  shortCodeSecret  String?      // hex 32 bytes — secret pour dériver le code TOTP-like
  prefilledData    Json         @default("{}")  // offerKey, setupAmount, monthlyAmount, notesAdmin
  status           String       @default("pending") // pending | in_progress | completed | expired | revoked
  completedAt      DateTime?
  codeValidatedAt  DateTime?
  failedAttempts   Int          @default(0)
  lockedUntil      DateTime?
  createdBy        String?      // userId de l'admin

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
  @@index([accessToken])
  @@index([contactEmail])
}

model OrganizationBilling {
  id                      String       @id @default(cuid())
  organizationId          String       @unique
  offerKey                String?
  setupAmount             Int?         // en centimes
  monthlyAmount           Int?         // en centimes
  subscriptionStatus      String       @default("inactive") // inactive | pending | active | past_due | canceled

  // Champs Stripe — préparés, vides en V1
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  stripeCheckoutSessionId String?

  isSimulated             Boolean      @default(true)
  activatedAt             DateTime?

  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

model ClientDocument {
  id              String       @id @default(cuid())
  organizationId  String
  title           String
  description     String?
  category        String?      // contrat | facture | brief | livrable | suivi
  storagePath     String?
  externalUrl     String?
  createdBy       String?      // userId
  createdByRole   AppRole?
  visibleToClient Boolean      @default(true)
  uploadedBy      String?      // userId

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, visibleToClient])
}

model OrganizationFeature {
  id              String       @id @default(cuid())
  organizationId  String
  featureKey      String       // documents | billing | crm | loyalty_card | ai_followup | acquisition | reservation
  enabled         Boolean      @default(false)

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())

  @@unique([organizationId, featureKey])
  @@index([organizationId])
}
