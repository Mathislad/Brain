generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProspectStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Prospect {
  id             String         @id @default(cuid())
  userId         String

  nom            String
  entreprise     String?
  email          String?
  telephone      String?
  ville          String?
  activite       String?

  status         ProspectStatus @default(TODO)
  canal          String?
  source         String?

  instagram      String?
  facebook       String?
  linkedin       String?
  siteInternet   String?

  note             String?
  prochaineAction  String?
  derniereAction   String?
  provenance       String?

  // Facturation (client)
  formule        String?
  montantTotal   Int?       // en centimes
  devisSigne     Boolean    @default(false)
  payments       Payment[]

  // Référence externe pour la déduplication lors des imports
  externalId     String?
  externalSource String?
  recuLe         DateTime?

  links          ClientLink[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, externalId])
}

model ClientLink {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  // "PROJECT" | "FILE" | "WEB" | "CONTACT"
  category   String
  label      String
  value      String

  createdAt  DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  amount     Int      // en centimes
  label      String?
  paidAt     DateTime @default(now())

  createdAt  DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
}
