generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProspectStatus {
  TODO
  IN_PROGRESS
  DONE
  CLIENT_ACTIF
}

enum AppRole {
  OWNER
  ADMIN
  CLIENT
}

model Prospect {
  id             String         @id @default(cuid())
  userId         String

  nom            String
  entreprise     String?
  email          String?
  telephone      String?
  ville          String?
  activite       String?

  status         ProspectStatus @default(TODO)
  canal          String?
  source         String?

  instagram      String?
  facebook       String?
  linkedin       String?
  siteInternet   String?

  note             String?
  prochaineAction  String?
  derniereAction   String?
  provenance       String?
  interactions     Int        @default(0)  // nb d'échanges loggés (cold call)
  appelsAvecReponse Int       @default(0)
  appelsSansReponse Int       @default(0)

  // Facturation (client)
  formule        String?
  montantTotal   Int?       // en centimes
  devisSigne     Boolean    @default(false)
  payments       Payment[]
  todos          TodoItem[]
  csvImportId    String?
  csvImport      CsvImportBatch? @relation(fields: [csvImportId], references: [id], onDelete: SetNull)

  // Référence externe pour la déduplication lors des imports
  externalId     String?
  externalSource String?
  recuLe         DateTime?

  links          ClientLink[]
  documents      Document[]
  sites          Site[]
  organization   Organization?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, externalId])
  @@index([csvImportId])
}

model CsvImportBatch {
  id            String    @id @default(cuid())
  userId        String
  fileName      String?
  sourceRowCount Int      @default(0)
  importedCount Int       @default(0)
  revertedCount Int       @default(0)
  status        String    @default("ACTIVE") // ACTIVE | REVERTED
  mapping       Json?
  createdAt     DateTime  @default(now())
  revertedAt    DateTime?

  prospects     Prospect[]

  @@index([userId])
  @@index([userId, status])
  @@index([createdAt])
}

model ClientLink {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  // "PROJECT" | "FILE" | "WEB" | "CONTACT"
  category   String
  label      String
  value      String

  createdAt  DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  amount     Int      // en centimes
  label      String?
  paidAt     DateTime @default(now())

  createdAt  DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
}

model AccountingEntry {
  id        String   @id @default(cuid())
  userId    String

  // "income" | "expense"
  type      String
  title     String
  amount    Int      // en centimes
  date      DateTime
  note      String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model Document {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  // "DEVIS" | "FACTURE" | "CONTRAT"
  type       String
  templateId String
  reference  String
  title      String
  // "DRAFT" | "SENT" | "SIGNED" | "PAID" | "CANCELLED"
  status     String   @default("DRAFT")
  amount     Int?     // en centimes
  data       Json?
  issuedAt   DateTime @default(now())

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([userId, type, reference])
  @@index([userId])
  @@index([prospectId])
  @@index([userId, type])
}

// ─── Liste rouge « Ne pas rappeler » ────────────────────────────────────────
model DoNotCall {
  id              String   @id @default(cuid())
  userId          String

  phone           String
  normalizedPhone String
  note            String?

  createdAt       DateTime @default(now())

  @@unique([userId, normalizedPhone])
  @@index([userId])
}

// ─── Todolist ────────────────────────────────────────────────────────────────
model TodoItem {
  id        String   @id @default(cuid())
  userId    String
  prospectId String?

  title     String
  context   String?
  status    String   @default("TODO")    // TODO | IN_PROGRESS | DONE
  priority  String   @default("MEDIUM")  // LOW | MEDIUM | HIGH
  dueDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  prospect  Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([prospectId])
  @@index([userId, status])
}

// ─── Réseaux sociaux — idées de contenu ─────────────────────────────────────
model ContentIdea {
  id            String   @id @default(cuid())
  userId        String

  title         String
  angle         String?
  format        String   // "simple" | "short"
  platform      String
  plannedSlotId String?
  steps         Json     @default("{}")  // { script, tournage, montage, publication }

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ─── Agenda — connexion Google Calendar ─────────────────────────────────────
model GoogleCalendarConnection {
  id           String   @id @default(cuid())
  userId       String   @unique

  googleEmail  String?
  accessToken  String
  refreshToken String?
  tokenType    String?
  scope        String?
  expiresAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

// ─── Contrats ────────────────────────────────────────────────────────────────
model Contrat {
  id         String   @id @default(cuid())
  userId     String

  clientNom  String
  clientSiret String?
  services   String[]
  total      String?
  dureeMois  Int
  dateDebut  DateTime?
  dateSig    DateTime?
  statut     String   @default("brouillon") // brouillon | envoye | signe | archive
  storagePath String?                        // chemin dans Supabase Storage
  formData   Json                            // toutes les vars pour régénération
  notes      String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([userId, statut])
}

// ─── Bibliothèque de prompts ─────────────────────────────────────────────────
model Prompt {
  id        String   @id @default(cuid())
  userId    String

  title     String
  category  String
  content   String
  tags      String[]
  favorite  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, category])
}

// ─── CMS « Site internet » ──────────────────────────────────────────────────
// Site = back-office du site d'un client. Le site live (construit séparément)
// lit ce contenu via l'API publique /api/public/site/[slug].
model Site {
  id         String   @id @default(cuid())
  userId     String              // propriétaire F5L
  prospectId String?             // lien optionnel vers la fiche client (Prospect)

  name       String
  slug       String   @unique    // identifiant public pour l'API
  domain     String?             // domaine du site live (futur: restreindre le CORS)
  logoUrl    String?
  published  Boolean  @default(true)

  items      SiteItem[]
  prospect   Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

model SiteItem {
  id          String   @id @default(cuid())
  userId      String
  siteId      String

  type        String   // "OFFER" | "PRODUCT"
  title       String
  description String?
  price       Int?     // en centimes
  imageUrl    String?
  order       Int      @default(0)
  visible     Boolean  @default(true)

  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([siteId])
}

// ─── Portail client F5L Brain ────────────────────────────────────────────────

model Organization {
  id             String               @id @default(cuid())
  name           String
  type           String               @default("client")  // 'client' | 'internal'
  status         String               @default("pending") // 'pending' | 'active' | 'suspended'
  prospectId     String?              @unique

  // Entité légale — renseignée/corrigée pendant l'onboarding, lue par devis/contrats
  siret          String?
  adresse        String?
  formeJuridique String?
  representant   String?

  prospect       Prospect?            @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  members        OrganizationMember[]
  billing        OrganizationBilling?
  invitations    ClientInvitation[]
  documents      ClientDocument[]
  features       OrganizationFeature[]
  services       F5lService[]
  websiteProjects WebsiteProject[]
  adAccounts     AdAccount[]
  adCampaigns    AdCampaign[]
  crmPipelineStages CrmPipelineStage[]
  crmLeads       CrmLead[]
  automations    ClientAutomation[]
  aiAgents       AiAgent[]
  aiAgentLogs    AiAgentLog[]
  requests       ClientRequest[]
  notifications  ClientNotification[]

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([type])
  @@index([status])
  @@index([prospectId])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           AppRole      @default(CLIENT)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model ClientInvitation {
  id               String       @id @default(cuid())
  organizationId   String
  contactEmail     String
  accessToken      String       @unique
  tokenExpiresAt   DateTime
  shortCodeSecret  String?      // hex 32 bytes — secret pour dériver le code TOTP-like
  prefilledData    Json         @default("{}")  // offerKey, setupAmount, monthlyAmount, notesAdmin
  status           String       @default("pending") // pending | in_progress | completed | expired | revoked
  completedAt      DateTime?
  codeValidatedAt  DateTime?
  failedAttempts   Int          @default(0)
  lockedUntil      DateTime?
  createdBy        String?      // userId de l'admin

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
  @@index([accessToken])
  @@index([contactEmail])
}

model OrganizationBilling {
  id                      String       @id @default(cuid())
  organizationId          String       @unique
  offerKey                String?
  setupAmount             Int?         // en centimes
  monthlyAmount           Int?         // en centimes
  subscriptionStatus      String       @default("inactive") // inactive | pending | active | past_due | canceled

  // Champs Stripe — préparés, vides en V1
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  stripeCheckoutSessionId String?

  isSimulated             Boolean      @default(true)
  activatedAt             DateTime?

  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

model ClientDocument {
  id              String       @id @default(cuid())
  organizationId  String
  serviceId       String?
  title           String
  description     String?
  category        String?      // contrat | facture | brief | livrable | suivi
  storagePath     String?
  externalUrl     String?
  createdBy       String?      // userId
  createdByRole   AppRole?
  visibleToClient Boolean      @default(true)
  uploadedBy      String?      // userId

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service         F5lService?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([serviceId])
  @@index([organizationId, visibleToClient])
}

model OrganizationFeature {
  id              String       @id @default(cuid())
  organizationId  String
  featureKey      String       // documents | billing | crm | loyalty_card | ai_followup | acquisition | reservation
  enabled         Boolean      @default(false)

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())

  @@unique([organizationId, featureKey])
  @@index([organizationId])
}

model F5lService {
  id             String          @id @default(cuid())
  organizationId String

  // website | meta_ads | google_ads | crm | ai_agent | automation | support
  type           String
  name           String
  status         String          @default("planned") // planned | active | paused | done | attention
  progress       Int             @default(0)
  description    String?
  startedAt      DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  websiteProjects WebsiteProject[]
  adCampaigns    AdCampaign[]
  documents      ClientDocument[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, status])
}

model WebsiteProject {
  id                String        @id @default(cuid())
  organizationId    String
  serviceId         String?

  domain            String?
  previewUrl        String?
  productionUrl     String?
  status            String        @default("planned")
  currentStep       String?
  progress          Int           @default(0)
  contentStatus     String        @default("waiting")
  designStatus      String        @default("planned")
  developmentStatus String        @default("planned")
  deploymentStatus  String        @default("planned")

  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service           F5lService?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  tasks             WebsiteTask[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([organizationId])
  @@index([serviceId])
  @@index([organizationId, status])
}

model WebsiteTask {
  id               String         @id @default(cuid())
  websiteProjectId String
  title            String
  status           String         @default("todo")
  assignedTo       String?
  dueDate          DateTime?

  websiteProject   WebsiteProject @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([websiteProjectId])
  @@index([websiteProjectId, status])
}

model AdAccount {
  id                String       @id @default(cuid())
  organizationId    String
  platform          String       // meta | google
  accountName       String
  externalAccountId String?
  status            String       @default("pending")

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, platform])
}

model AdCampaign {
  id             String       @id @default(cuid())
  organizationId String
  serviceId      String?
  platform       String       // meta | google
  name           String
  status         String       @default("draft")
  objective      String?
  budget         Int?         // centimes
  spend          Int?         // centimes
  leads          Int          @default(0)
  cpl            Int?         // centimes
  impressions    Int          @default(0)
  clicks         Int          @default(0)
  conversions    Int          @default(0)
  startDate      DateTime?
  endDate        DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service        F5lService?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([serviceId])
  @@index([organizationId, platform])
  @@index([organizationId, status])
}

model CrmPipelineStage {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  position       Int          @default(0)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, position])
}

model CrmLead {
  id             String       @id @default(cuid())
  organizationId String
  fullName       String
  email          String?
  phone          String?
  source         String?
  status         String       @default("new")
  value          Int?         // centimes
  lastContactAt  DateTime?
  nextActionAt   DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model ClientAutomation {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  type           String
  status         String       @default("planned")
  description    String?
  lastRunAt      DateTime?
  nextRunAt      DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
}

model AiAgent {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  role           String
  status         String       @default("planned")
  description    String?
  lastActivityAt DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs           AiAgentLog[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
}

model AiAgentLog {
  id             String       @id @default(cuid())
  agentId        String?
  organizationId String
  type           String
  content        String
  status         String       @default("done")

  agent          AiAgent?     @relation(fields: [agentId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())

  @@index([agentId])
  @@index([organizationId])
  @@index([organizationId, createdAt])
}

model ClientRequest {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  category       String
  title          String
  description    String
  status         String       @default("open") // open | in_progress | waiting_client | done
  priority       String       @default("normal")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([userId])
}

model ClientNotification {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  title          String
  message        String
  readAt         DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, readAt])
}
