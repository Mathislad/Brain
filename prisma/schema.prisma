generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProspectStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Prospect {
  id             String         @id @default(cuid())
  userId         String

  nom            String
  entreprise     String?
  email          String?
  telephone      String?
  ville          String?
  activite       String?

  status         ProspectStatus @default(TODO)
  canal          String?
  source         String?

  instagram      String?
  facebook       String?
  linkedin       String?
  siteInternet   String?

  note             String?
  prochaineAction  String?
  derniereAction   String?
  provenance       String?

  // Facturation (client)
  formule        String?
  montantTotal   Int?       // en centimes
  devisSigne     Boolean    @default(false)
  payments       Payment[]

  // Référence externe pour la déduplication lors des imports
  externalId     String?
  externalSource String?
  recuLe         DateTime?

  links          ClientLink[]
  documents      Document[]
  sites          Site[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, externalId])
}

model ClientLink {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  // "PROJECT" | "FILE" | "WEB" | "CONTACT"
  category   String
  label      String
  value      String

  createdAt  DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  amount     Int      // en centimes
  label      String?
  paidAt     DateTime @default(now())

  createdAt  DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
}

model AccountingEntry {
  id        String   @id @default(cuid())
  userId    String

  // "income" | "expense"
  type      String
  title     String
  amount    Int      // en centimes
  date      DateTime
  note      String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model Document {
  id         String   @id @default(cuid())
  userId     String
  prospectId String

  // "DEVIS" | "FACTURE" | "CONTRAT"
  type       String
  templateId String
  reference  String
  title      String
  // "DRAFT" | "SENT" | "SIGNED" | "PAID" | "CANCELLED"
  status     String   @default("DRAFT")
  amount     Int?     // en centimes
  data       Json?
  issuedAt   DateTime @default(now())

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([userId, type, reference])
  @@index([userId])
  @@index([prospectId])
  @@index([userId, type])
}

// ─── Liste rouge « Ne pas rappeler » ────────────────────────────────────────
model DoNotCall {
  id              String   @id @default(cuid())
  userId          String

  phone           String
  normalizedPhone String
  note            String?

  createdAt       DateTime @default(now())

  @@unique([userId, normalizedPhone])
  @@index([userId])
}

// ─── Todolist ────────────────────────────────────────────────────────────────
model TodoItem {
  id        String   @id @default(cuid())
  userId    String

  title     String
  context   String?
  status    String   @default("TODO")    // TODO | IN_PROGRESS | DONE
  priority  String   @default("MEDIUM")  // LOW | MEDIUM | HIGH
  dueDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

// ─── Réseaux sociaux — idées de contenu ─────────────────────────────────────
model ContentIdea {
  id            String   @id @default(cuid())
  userId        String

  title         String
  angle         String?
  format        String   // "simple" | "short"
  platform      String
  plannedSlotId String?
  steps         Json     @default("{}")  // { script, tournage, montage, publication }

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ─── Lancement — configuration des sessions ──────────────────────────────────
model LaunchConfig {
  id        String   @id @default(cuid())
  userId    String   @unique

  sessions  Json     @default("[]")  // LaunchSession[]

  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── CMS « Site internet » ──────────────────────────────────────────────────
// Site = back-office du site d'un client. Le site live (construit séparément)
// lit ce contenu via l'API publique /api/public/site/[slug].
model Site {
  id         String   @id @default(cuid())
  userId     String              // propriétaire F5L
  prospectId String?             // lien optionnel vers la fiche client (Prospect)

  name       String
  slug       String   @unique    // identifiant public pour l'API
  domain     String?             // domaine du site live (futur: restreindre le CORS)
  logoUrl    String?
  published  Boolean  @default(true)

  items      SiteItem[]
  prospect   Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

model SiteItem {
  id          String   @id @default(cuid())
  userId      String
  siteId      String

  type        String   // "OFFER" | "PRODUCT"
  title       String
  description String?
  price       Int?     // en centimes
  imageUrl    String?
  order       Int      @default(0)
  visible     Boolean  @default(true)

  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([siteId])
}
